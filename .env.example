# LLM provider
OPENAI_API_KEY=your-nvidia-nim-api-key
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=moonshotai/kimi-k2.6

# LangSmith tracing
# Official docs recommend LANGSMITH_* names for new projects.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=local-langchain-agent
# Optional region/self-hosted endpoint:
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Local server
HOST=127.0.0.1
PORT=8000
